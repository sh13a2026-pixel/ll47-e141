# ===========================================================================
# LL47 e141 backend — biến môi trường
# Copy file này thành `.env` rồi điền giá trị thật.
# ===========================================================================

# Cổng HTTP backend lắng nghe
PORT=8080

# URL công khai của backend (dùng để dựng downloadURL cho file upload).
# Khi deploy lên Render đổi thành https://<ten-app>.onrender.com
PUBLIC_URL=http://localhost:8080

# ---- MongoDB ----
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ll47

# ---- JWT (auth) ----
# BẮT BUỘC đổi sang chuỗi ngẫu nhiên dài khi chạy thật.
JWT_SECRET=doi-chuoi-bi-mat-nay-thanh-ngau-nhien
# Thời gian sống idToken (giây). Mặc định 1 giờ.
JWT_EXPIRES_IN=3600
# Thời gian sống refresh token (ngày).
REFRESH_TTL_DAYS=30

# ---- CORS ----
# '*' cho dev. Khi production nên đặt domain cụ thể, ngăn cách bằng dấu phẩy.
CORS_ORIGIN=*

# ---- File upload (GridFS) ----
# Giới hạn dung lượng 1 file (MB).
MAX_UPLOAD_MB=25

# ---- FCM push nền (tuỳ chọn) ----
# Để gửi push khi app đóng, dán toàn bộ JSON service account của Firebase
# vào 1 dòng (escape) HOẶC đặt FIREBASE_SERVICE_ACCOUNT_PATH trỏ tới file .json.
# Nếu để trống, backend vẫn chạy bình thường nhưng KHÔNG gửi push nền.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=
